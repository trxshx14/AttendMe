<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FB">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F2D5E"
        app:title="Attendance History"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#FFFFFF"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Error -->
            <TextView android:id="@+id/tvError"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_error" android:padding="12dp"
                android:textColor="#DC2626" android:textSize="13sp"
                android:visibility="gone" android:layout_marginBottom="12dp"/>

            <!-- Filter Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <!-- Search -->
                    <EditText android:id="@+id/etSearch"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:hint="Search by name or roll number..."
                        android:background="@drawable/bg_search_input"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textColor="#0F2D5E" android:textColorHint="#94A3B8"
                        android:textSize="13sp" android:inputType="text"
                        android:singleLine="true" android:layout_marginBottom="14dp"/>

                    <!-- Class -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CLASS" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                    <Spinner android:id="@+id/spinnerClass"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input" android:paddingStart="14dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Status -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="STATUS" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                    <Spinner android:id="@+id/spinnerStatus"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input" android:paddingStart="14dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Date Range -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="14dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="FROM" android:textSize="11sp" android:textStyle="bold"
                                android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                            <EditText android:id="@+id/etDateFrom"
                                android:layout_width="match_parent" android:layout_height="48dp"
                                android:hint="Start date" android:background="@drawable/bg_input"
                                android:paddingStart="14dp" android:paddingEnd="14dp"
                                android:textColor="#0F2D5E" android:textColorHint="#94A3B8"
                                android:textSize="13sp" android:focusable="false" android:clickable="true"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TO" android:textSize="11sp" android:textStyle="bold"
                                android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                            <EditText android:id="@+id/etDateTo"
                                android:layout_width="match_parent" android:layout_height="48dp"
                                android:hint="End date" android:background="@drawable/bg_input"
                                android:paddingStart="14dp" android:paddingEnd="14dp"
                                android:textColor="#0F2D5E" android:textColorHint="#94A3B8"
                                android:textSize="13sp" android:focusable="false" android:clickable="true"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Buttons -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnApplyFilters"
                            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                            android:text="Apply Filters" android:textColor="#FFFFFF"
                            android:backgroundTint="#0F2D5E" android:stateListAnimator="@null"
                            android:layout_marginEnd="8dp" app:cornerRadius="12dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearFilters"
                            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                            android:text="Clear" android:textColor="#0F2D5E"
                            android:backgroundTint="#EBF2FF" android:stateListAnimator="@null"
                            app:cornerRadius="12dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Result count -->
            <TextView android:id="@+id/tvResultCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 records" android:textSize="12sp" android:textColor="#64748B"
                android:layout_marginBottom="8dp"/>

            <!-- Loading -->
            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:indeterminateTint="#0F2D5E"
                android:visibility="gone" android:layout_marginTop="24dp" android:layout_marginBottom="24dp"/>

            <!-- Empty -->
            <LinearLayout android:id="@+id/layoutEmpty"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center"
                android:padding="48dp" android:background="@drawable/bg_empty_state"
                android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📋" android:textSize="48sp" android:layout_marginBottom="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="No Records Found" android:textSize="16sp" android:textStyle="bold"
                    android:textColor="#0F2D5E" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Try adjusting your filters or date range."
                    android:textSize="13sp" android:textColor="#64748B" android:gravity="center"/>
            </LinearLayout>

            <!-- Records -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecords"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" android:visibility="gone"/>

            <!-- Pagination -->
            <LinearLayout android:id="@+id/layoutPagination"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:layout_marginTop="12dp" android:visibility="gone">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrevPage"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:text="← Prev" android:textSize="12sp"
                    android:textColor="#0F2D5E" android:backgroundTint="#EBF2FF"
                    android:stateListAnimator="@null" android:layout_marginEnd="12dp"
                    app:cornerRadius="10dp"/>
                <TextView android:id="@+id/tvPageInfo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1 / 1" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="#0F2D5E"
                    android:layout_marginEnd="12dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextPage"
                    android:layout_width="wrap_content" android:layout_height="40dp"
                    android:text="Next →" android:textSize="12sp"
                    android:textColor="#0F2D5E" android:backgroundTint="#EBF2FF"
                    android:stateListAnimator="@null" app:cornerRadius="10dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>