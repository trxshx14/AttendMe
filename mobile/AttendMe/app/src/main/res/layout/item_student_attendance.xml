<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@android:color/white"
    android:layout_marginBottom="2dp">

    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_dot_navy"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:text="TC"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trisha Cararag"
            android:textColor="#0F2D5E"
            android:textStyle="bold"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/tvRollNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2022-0001"
            android:textColor="#64748B"
            android:textSize="12sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnPresent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="P"
            android:padding="8dp"
            android:textStyle="bold"
            android:background="?android:attr/selectableItemBackground"/>

        <TextView
            android:id="@+id/btnAbsent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:padding="8dp"
            android:textStyle="bold"
            android:background="?android:attr/selectableItemBackground"/>

        <TextView
            android:id="@+id/btnLate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L"
            android:padding="8dp"
            android:textStyle="bold"
            android:background="?android:attr/selectableItemBackground"/>
    </LinearLayout>
</LinearLayout>