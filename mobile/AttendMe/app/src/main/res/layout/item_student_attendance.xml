<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: avatar + name + roll -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Avatar -->
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_navy"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <TextView
                    android:id="@+id/tvInitials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JD"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Name + Roll -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Juan dela Cruz"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#0F2D5E"/>
                <TextView
                    android:id="@+id/tvRollNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024-0001"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Current status badge -->
            <TextView
                android:id="@+id/tvCurrentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Present"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#16A34A"
                android:background="@drawable/bg_status_active"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </LinearLayout>

        <!-- Status buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPresent"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="✓ Present"
                android:textSize="11sp"
                android:textColor="#16A34A"
                android:backgroundTint="#D1FAE5"
                android:stateListAnimator="@null"
                android:layout_marginEnd="4dp"
                app:cornerRadius="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAbsent"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="✗ Absent"
                android:textSize="11sp"
                android:textColor="#DC2626"
                android:backgroundTint="#FEE2E2"
                android:stateListAnimator="@null"
                android:layout_marginEnd="4dp"
                app:cornerRadius="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLate"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="⏰ Late"
                android:textSize="11sp"
                android:textColor="#D97706"
                android:backgroundTint="#FEF3C7"
                android:stateListAnimator="@null"
                android:layout_marginEnd="4dp"
                app:cornerRadius="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExcused"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="📄 Excused"
                android:textSize="11sp"
                android:textColor="#7C3AED"
                android:backgroundTint="#EDE9FE"
                android:stateListAnimator="@null"
                app:cornerRadius="20dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>