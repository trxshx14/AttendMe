<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_student_item"
    android:layout_marginBottom="8dp">

    <!-- Avatar -->
    <LinearLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_icon_navy"
        android:gravity="center"
        android:layout_marginEnd="12dp">
        <TextView
            android:id="@+id/tvRecordInitials"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JD"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRecordName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Juan dela Cruz"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#0F2D5E"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="3dp">
            <TextView
                android:id="@+id/tvRecordRoll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roll: 001"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/tvRecordDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mar 19"
                android:textSize="11sp"
                android:textColor="#64748B"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Status Badge -->
    <TextView
        android:id="@+id/tvRecordStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Present"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@drawable/bg_status_active"/>

</LinearLayout>