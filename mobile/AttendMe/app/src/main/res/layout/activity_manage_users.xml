<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FB">

    <!-- Top Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F2D5E"
        app:title="Manage Teachers"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#FFFFFF"/>

    <!-- Stats Row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="#FFFFFF"
        android:padding="12dp" android:elevation="2dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_stat_card_left" android:padding="10dp" android:layout_marginEnd="4dp">
            <TextView android:id="@+id/tvStatTotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="20sp" android:textStyle="bold" android:textColor="#0F2D5E"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TOTAL" android:textSize="9sp" android:textStyle="bold"
                android:textColor="#64748B" android:letterSpacing="0.06"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_stat_card_left" android:padding="10dp" android:layout_marginEnd="4dp">
            <TextView android:id="@+id/tvStatAdmins"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="20sp" android:textStyle="bold" android:textColor="#0F2D5E"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ADMINS" android:textSize="9sp" android:textStyle="bold"
                android:textColor="#64748B" android:letterSpacing="0.06"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_stat_card_left" android:padding="10dp" android:layout_marginEnd="4dp">
            <TextView android:id="@+id/tvStatTeachers"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="20sp" android:textStyle="bold" android:textColor="#0F2D5E"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TEACHERS" android:textSize="9sp" android:textStyle="bold"
                android:textColor="#64748B" android:letterSpacing="0.06"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_stat_card_left" android:padding="10dp">
            <TextView android:id="@+id/tvStatActive"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="20sp" android:textStyle="bold" android:textColor="#0F2D5E"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ACTIVE" android:textSize="9sp" android:textStyle="bold"
                android:textColor="#64748B" android:letterSpacing="0.06"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:padding="12dp">
        <EditText android:id="@+id/etSearch"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:hint="Search by name or email..." android:textSize="14sp"
            android:textColor="#0F2D5E" android:textColorHint="#94A3B8"
            android:background="@drawable/bg_search_input"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="text" android:imeOptions="actionSearch" android:singleLine="true"/>
    </LinearLayout>

    <!-- Error -->
    <TextView android:id="@+id/tvError"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_error" android:padding="12dp"
        android:textColor="#DC2626" android:textSize="13sp"
        android:visibility="gone" android:layout_margin="12dp"/>

    <!-- Loading -->
    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:indeterminateTint="#0F2D5E"
        android:visibility="gone" android:layout_marginTop="32dp"/>

    <!-- Empty State -->
    <LinearLayout android:id="@+id/layoutEmpty"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:padding="48dp" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="👥" android:textSize="48sp" android:layout_marginBottom="16dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No users found" android:textSize="16sp" android:textStyle="bold"
            android:textColor="#0F2D5E" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tap + to add a new user" android:textSize="13sp" android:textColor="#64748B"/>
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUsers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#0F2D5E"
        app:tint="#FFFFFF"
        android:contentDescription="Add User"/>

</LinearLayout>