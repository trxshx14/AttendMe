<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#0F2D5E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GOOD MORNING"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#AAC4E0"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvTeacherName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Teacher"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👋"
                        android:textSize="28sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to take attendance for your classes today?"
                    android:textSize="13sp"
                    android:textColor="#AAC4E0"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_date_pill"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="13sp"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvCurrentDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monday, April 1, 2026"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardNextClass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#071A3E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_white_alpha"
                    android:layout_marginEnd="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="20sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:id="@+id/tvNextClassEyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR NEXT CLASS"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="#AAC4E0"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvNextClassName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade 10 — Sampaguita"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvNextClassMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8:00 AM – 9:00 AM · 35 students"
                        android:textSize="11sp"
                        android:textColor="#AAC4E0"/>
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnNextTakeAttendance"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Take →"
                    android:textColor="#0F2D5E"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="#FFFFFF"
                    app:cornerRadius="18dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnTakeAttendance"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Take\nAttendance"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#0F2D5E"
                android:paddingHorizontal="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnViewHistory"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Attendance History"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#0F2D5E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnReports"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="Reports"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#0F2D5E"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp"
                    android:background="@drawable/bg_stat_card_left">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📖" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MY CLASSES" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="#64748B" android:letterSpacing="0.06"/>
                    <TextView android:id="@+id/tvStatClasses"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#0F2D5E"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp"
                    android:background="@drawable/bg_stat_card_left">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎓" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TOTAL STUDENTS" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="#64748B" android:letterSpacing="0.06"/>
                    <TextView android:id="@+id/tvStatStudents"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#0F2D5E"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp"
                    android:background="@drawable/bg_stat_card_left">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PRESENT TODAY" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="#64748B" android:letterSpacing="0.06"/>
                    <TextView android:id="@+id/tvStatPresent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#0F2D5E"/>
                    <TextView android:id="@+id/tvStatPresentSub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0% of marked" android:textSize="10sp" android:textColor="#94A3B8"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp"
                    android:background="@drawable/bg_stat_card_left">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="❌" android:textSize="22sp" android:layout_marginBottom="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ABSENT / LATE" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="#64748B" android:letterSpacing="0.06"/>
                    <TextView android:id="@+id/tvStatAbsentLate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#0F2D5E"/>
                    <TextView android:id="@+id/tvStatAbsentLateSub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 late · 0 absent" android:textSize="10sp" android:textColor="#94A3B8"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="My Classes" android:textSize="16sp" android:textStyle="bold"
            android:textColor="#0F2D5E" android:layout_marginBottom="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardCornerRadius="20dp"
            app:cardElevation="2dp" app:cardBackgroundColor="#FFFFFF">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:background="#FAFCFF">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="📖  Current Load"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#0F2D5E"/>
                    <TextView android:id="@+id/btnTakeAttendanceInline"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Quick Take ›" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#1E50A2" android:background="@drawable/bg_chip_blue"
                        android:paddingHorizontal="12dp" android:paddingVertical="6dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/llClassesList"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Daily Summary" android:textSize="16sp" android:textStyle="bold"
            android:textColor="#0F2D5E" android:layout_marginBottom="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" app:cardCornerRadius="20dp"
            app:cardElevation="2dp" app:cardBackgroundColor="#FFFFFF">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="#FAFCFF">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📊  Status Report"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#0F2D5E"/>

                    <TextView
                        android:id="@+id/tvDateChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apr 1"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0F2D5E"
                        android:background="@drawable/bg_chip_blue"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Total Marked Today"
                            android:textSize="14sp" android:textStyle="bold" android:textColor="#0F2D5E"/>
                        <TextView android:id="@+id/tvSummaryTotal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="#0F2D5E"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sign Out"
            android:textColor="#DC2626"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#FEE2E2"
            app:cornerRadius="12dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>