<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar (clickable to change photo) -->
        <FrameLayout
            android:id="@+id/frameAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="14dp"
            android:clickable="true"
            android:focusable="true">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/bg_circle_navy"/>

            <!-- Initials fallback -->
            <LinearLayout
                android:id="@+id/layoutInitials"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_icon_navy"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tvInitials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AB"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Camera overlay badge -->
            <LinearLayout
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/bg_circle_navy"
                android:gravity="center"
                android:layout_gravity="bottom|end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="8sp"/>
            </LinearLayout>

        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFullName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#0F2D5E"/>

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="john@school.edu"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#1E50A2"
                    android:background="@drawable/bg_detail_chip_blue"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"
                    android:background="@drawable/bg_status_active"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginBottom="6dp"
                android:backgroundTint="#EBF2FF"
                android:padding="0dp"
                android:stateListAnimator="@null"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_pencil_edit"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="#0F2D5E" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleActive"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginBottom="6dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="#EBF2FF"
                android:stateListAnimator="@null"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_pause_standard"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="#0F2D5E" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:backgroundTint="#FEE2E2"
                android:stateListAnimator="@null"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_trash_delete"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="20dp"
                app:iconTint="#0F2D5E" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>