<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FB">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F2D5E"
        app:title="Take Attendance"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#FFFFFF"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Error -->
            <TextView android:id="@+id/tvError"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_error" android:padding="12dp"
                android:textColor="#DC2626" android:textSize="13sp"
                android:visibility="gone" android:layout_marginBottom="12dp"/>

            <!-- Selector Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SELECT CLASS" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                    <Spinner android:id="@+id/spinnerClass"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input" android:paddingStart="14dp"
                        android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="DATE" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etDate"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:textColor="#0F2D5E" android:textSize="14sp"
                        android:focusable="false" android:clickable="true"
                        android:layout_marginBottom="14dp"/>

                    <EditText android:id="@+id/etSearch"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:hint="Search by name or roll number..."
                        android:background="@drawable/bg_search_input"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textColor="#0F2D5E" android:textColorHint="#94A3B8"
                        android:textSize="13sp" android:inputType="text"
                        android:singleLine="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Summary Strip (4 chips) -->
            <LinearLayout android:id="@+id/layoutSummaryStrip"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp"
                android:visibility="gone">

                <TextView android:id="@+id/chipPresent"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="✓ 0\nPresent" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#16A34A" android:background="@drawable/bg_status_active"
                    android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/chipAbsent"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="✗ 0\nAbsent" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#DC2626" android:background="@drawable/bg_status_inactive"
                    android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/chipLate"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="⏰ 0\nLate" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#D97706" android:background="@drawable/bg_stat_late_badge"
                    android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/chipExcused"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="📄 0\nExcused" android:textSize="11sp" android:textStyle="bold"
                    android:textColor="#7C3AED" android:background="@drawable/bg_stat_excused_badge"
                    android:paddingTop="8dp" android:paddingBottom="8dp"/>
            </LinearLayout>

            <!-- Mark All Row -->
            <LinearLayout android:id="@+id/layoutMarkAll"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="10dp" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mark all:" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#64748B" android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkAllPresent"
                    android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="Present" android:textSize="10sp" android:textColor="#16A34A"
                    android:backgroundTint="#D1FAE5" android:stateListAnimator="@null"
                    android:layout_marginEnd="4dp" app:cornerRadius="20dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkAllAbsent"
                    android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="Absent" android:textSize="10sp" android:textColor="#DC2626"
                    android:backgroundTint="#FEE2E2" android:stateListAnimator="@null"
                    android:layout_marginEnd="4dp" app:cornerRadius="20dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkAllLate"
                    android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="Late" android:textSize="10sp" android:textColor="#D97706"
                    android:backgroundTint="#FEF3C7" android:stateListAnimator="@null"
                    android:layout_marginEnd="4dp" app:cornerRadius="20dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkAllExcused"
                    android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                    android:text="Excused" android:textSize="10sp" android:textColor="#7C3AED"
                    android:backgroundTint="#EDE9FE" android:stateListAnimator="@null"
                    app:cornerRadius="20dp"/>
            </LinearLayout>

            <!-- Loading -->
            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:indeterminateTint="#0F2D5E"
                android:visibility="gone" android:layout_marginTop="24dp" android:layout_marginBottom="24dp"/>

            <!-- Placeholder -->
            <LinearLayout android:id="@+id/layoutPlaceholder"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center"
                android:padding="48dp" android:background="@drawable/bg_empty_state">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👥" android:textSize="48sp" android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvPlaceholderTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Select a Class to Begin"
                    android:textSize="16sp" android:textStyle="bold"
                    android:textColor="#0F2D5E" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvPlaceholderSub"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Choose a class above to load students and start marking attendance."
                    android:textSize="13sp" android:textColor="#64748B" android:gravity="center"/>
            </LinearLayout>

            <!-- Students RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStudents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="💾  Save Attendance"
                android:textSize="15sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:backgroundTint="#0F2D5E"
                android:stateListAnimator="@null"
                android:layout_marginTop="16dp" android:visibility="gone"
                app:cornerRadius="14dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>