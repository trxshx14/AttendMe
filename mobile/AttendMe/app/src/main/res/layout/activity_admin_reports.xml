<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FB">

    <!-- Top Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F2D5E"
        app:title="Reports &amp; Analytics"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Report Type Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDaily"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Daily"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#0F2D5E"
                    android:stateListAnimator="@null"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_calendar_event"
                    app:iconGravity="textStart"
                    app:iconSize="18dp"
                    app:iconTint="#FFFFFF"
                    app:iconPadding="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWeekly"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Weekly"
                    android:textSize="13sp"
                    android:textColor="#0F2D5E"
                    android:backgroundTint="#EBF2FF"
                    android:stateListAnimator="@null"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_graph_bar"
                    app:iconGravity="textStart"
                    app:iconSize="18dp"
                    app:iconTint="#0F2D5E"
                    app:iconPadding="8dp"/>

            </LinearLayout>

            <!-- Filters Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Select Class -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SELECT CLASS" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                    <Spinner android:id="@+id/spinnerClass"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input" android:paddingStart="14dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Start Date -->
                    <TextView android:id="@+id/tvDateLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="DATE" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#0F2D5E" android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
                    <EditText android:id="@+id/etStartDate"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:hint="Select date" android:background="@drawable/bg_input"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:textColor="#0F2D5E" android:textColorHint="#94A3B8"
                        android:textSize="14sp" android:focusable="false" android:clickable="true"
                        android:layout_marginBottom="14dp"/>

                    <!-- End Date (weekly only) -->
                    <TextView android:id="@+id/tvEndDateLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="END DATE" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#0F2D5E" android:letterSpacing="0.06"
                        android:layout_marginBottom="6dp" android:visibility="gone"/>
                    <EditText android:id="@+id/etEndDate"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:hint="Select end date" android:background="@drawable/bg_input"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:textColor="#0F2D5E" android:textColorHint="#94A3B8"
                        android:textSize="14sp" android:focusable="false" android:clickable="true"
                        android:layout_marginBottom="14dp" android:visibility="gone"/>

                    <!-- Generate Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGenerate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Generate Report"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#0F2D5E"
                        android:stateListAnimator="@null"
                        app:cornerRadius="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Error -->
            <TextView android:id="@+id/tvError"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_error" android:padding="12dp"
                android:textColor="#DC2626" android:textSize="13sp"
                android:visibility="gone" android:layout_marginBottom="12dp"/>

            <!-- Loading -->
            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:indeterminateTint="#0F2D5E"
                android:visibility="gone" android:layout_marginBottom="12dp"/>

            <!-- Summary Cards -->
            <LinearLayout android:id="@+id/layoutSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <!-- TOTAL — full width -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_stat_card_left">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL RECORDS"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#64748B"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvSummaryTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="#0F2D5E"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Row: Present + Absent -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- PRESENT -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:background="@drawable/bg_stat_present">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PRESENT"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#64748B"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvSummaryPresent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#10B981"/>
                            <TextView
                                android:id="@+id/tvPresentRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#1E50A2"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ABSENT -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:background="@drawable/bg_stat_absent">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ABSENT"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#64748B"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvSummaryAbsent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#EF4444"/>
                            <TextView
                                android:id="@+id/tvAbsentRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#1E50A2"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Row: Late + Excused -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- LATE -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:background="@drawable/bg_stat_late">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LATE"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#64748B"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvSummaryLate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#F59E0B"/>
                            <TextView
                                android:id="@+id/tvLateRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#1E50A2"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- EXCUSED -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:background="@drawable/bg_stat_excused">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EXCUSED"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#64748B"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvSummaryExcused"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#8B5CF6"/>
                            <TextView
                                android:id="@+id/tvExcusedRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#1E50A2"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <!-- Records List -->
            <androidx.cardview.widget.CardView android:id="@+id/cardRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:id="@+id/tvRecordsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendance Records"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#0F2D5E"
                        android:layout_marginBottom="12dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Export CSV Button (shown after report is generated) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportCsv"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Export as CSV"
                android:textColor="#0F2D5E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#EBF2FF"
                android:stateListAnimator="@null"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_download"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconTint="#0F2D5E"
                app:iconPadding="8dp"/>

            <!-- Empty State -->
            <LinearLayout android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:background="@drawable/bg_empty_state"
                android:layout_marginTop="8dp">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:src="@drawable/ic_clipboard_assignment"
                    android:scaleType="centerInside"
                    app:tint="#0F2D5E" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Report Generated"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0F2D5E"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select a class and date, then tap Generate Report"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>